<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Minimal Hardened Runtime entitlements for cockpiT.
  allow-jit + allow-unsigned-executable-memory are required by Electron/V8;
  everything else stays locked down. Used only when the release is signed with
  a real Apple Developer ID (CI enables hardenedRuntime for that path).
-->
<plist version="1.0">
  <dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
  </dict>
</plist>
